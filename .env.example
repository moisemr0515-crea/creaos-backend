# ─── ENTORNO ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── BASE DE DATOS ───────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/creaos?retryWrites=true&w=majority

# ─── REDIS ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=cambia_este_secreto_muy_largo_y_seguro_min_32_chars
JWT_REFRESH_SECRET=otro_secreto_diferente_para_refresh_tokens_min_32
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── EMAIL (SMTP) ─────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tu_email@gmail.com
EMAIL_PASS=tu_app_password
EMAIL_FROM=CREA OS <noreply@creaos.com>

# ─── FRONTEND ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── SEGURIDAD ───────────────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12
