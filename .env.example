# ─── ENTORNO ─────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ─── BASE DE DATOS ────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/creaos?retryWrites=true&w=majority

# ─── REDIS ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://default:password@redis.railway.internal:6379

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=genera_con_openssl_rand_hex_64_minimo_32_caracteres
JWT_REFRESH_SECRET=diferente_al_anterior_openssl_rand_hex_64
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── SEGURIDAD ────────────────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ─── FRONTEND (URL del dashboard en producción) ───────────────────────────────
FRONTEND_URL=https://tu-frontend.vercel.app

# ─── CORS (orígenes adicionales permitidos, separados por coma) ───────────────
ALLOWED_ORIGINS=https://tu-frontend.vercel.app,https://otro-dominio.com

# ─── APP (URL pública del backend en Railway) ─────────────────────────────────
APP_URL=https://tu-backend.railway.app

# ─── CLOUDINARY (logo, fotos de producto, PDF informativo) ────────────────────
CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=tu-api-key
CLOUDINARY_API_SECRET=tu-api-secret

# ─── EMAIL (Resend — API HTTPS, sin SMTP) ─────────────────────────────────────
RESEND_API_KEY=re_tu_api_key
EMAIL_FROM=CREA OS <noreply@creaos.com>

# ─── OPENAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
AI_MAX_TOKENS=1000
AI_TEMPERATURE=0.7

# ─── META / FACEBOOK ADS ─────────────────────────────────────────────────────
META_APP_ID=tu_app_id_de_meta
META_APP_SECRET=tu_app_secret_de_meta
META_GRAPH_API_VERSION=v19.0

# ─── WHATSAPP BUSINESS API ───────────────────────────────────────────────────
# Token que configuras en Meta Business Suite → Webhooks
WHATSAPP_VERIFY_TOKEN=CREAOS_WHATSAPP_VERIFY_2026
# Token de acceso permanente de la API de WhatsApp
WHATSAPP_TOKEN=EAAxxxxxx...
# ID del número de teléfono de WhatsApp Business
WHATSAPP_PHONE_ID=123456789012345
# App secret de la Meta App bajo la que está el WhatsApp Business Account (para x-hub-signature-256).
# Dejar vacío si es la misma Meta App que Facebook Lead Ads (usa META_APP_SECRET como fallback).
WHATSAPP_APP_SECRET=

# ─── TIKTOK ADS ──────────────────────────────────────────────────────────────
TIKTOK_APP_SECRET=tu_app_secret_de_tiktok

# ─── GUPSHUP (WHATSAPP) ──────────────────────────────────────────────────────
# API Key de la app en Gupshup (dashboard → app → API Keys)
GUPSHUP_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Nombre de la app en Gupshup
GUPSHUP_APP_NAME=CREAOS
# Número de teléfono de origen (WhatsApp Business), sin "+"
GUPSHUP_PHONE_NUMBER=51900000000
# WABA ID de la cuenta de WhatsApp Business
GUPSHUP_WABA_ID=
# Credenciales de Basic Auth configuradas en el panel de Gupshup (Webhook → Basic Authentication)
GUPSHUP_WEBHOOK_USER=
GUPSHUP_WEBHOOK_PASS=

# ─── STRIPE ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLIC_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── MERCADO PAGO ─────────────────────────────────────────────────────────────
MP_ACCESS_TOKEN=APP_USR-...
MP_PUBLIC_KEY=APP_USR-...
# Secreto HMAC configurado en el panel de MP (Tus integraciones → Webhooks) para verificar la firma x-signature
MP_WEBHOOK_SECRET=
